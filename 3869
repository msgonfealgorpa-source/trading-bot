SYMBOLS = ['BTC/USDT', 'ETH/USDT', 'SOL/USDT']
TRADE_AMOUNT_USDT = 10 
TAKE_PROFIT = 1.5  
STOP_LOSS = -1.0  

def is_smart_entry(symbol, exchange):
    try:
        ohlcv = exchange.fetch_ohlcv(symbol, '15m', limit=14)
        df = pd.DataFrame(ohlcv, columns=['timestamp', 'open', 'high', 'low', 'close', 'volume'])
        df['rsi'] = ta.momentum.rsi(df['close'], window=14)
        current_rsi = df['rsi'].iloc[-1]
        
        print(f"تحليل {symbol} | قيمة RSI: {current_rsi:.2f}")
        
        if current_rsi < 30:
            return True
        return False
    except Exception as e:
        print(f"خطأ في التحليل: {e}")
        return False

def start_bot():
    exchange = ccxt.gateio({'apiKey': API_KEY, 'secret': API_SECRET, 'enableRateLimit': True})
    print("🚀 تم تشغيل البوت (تم إضافة معلمة السعر لـ v2)... جاري التحليل")
    
    while True:
        for symbol in SYMBOLS:
            try:
                if is_smart_entry(symbol, exchange):
                    print(f"🎯 فرصة ذكية في {symbol}! جاري حساب الكمية وشراء...")
                    
                    # 1. جلب السعر الحالي
                    ticker = exchange.fetch_ticker(symbol)
                    current_price = ticker['last']
                    
                    # 2. حساب الكمية
                    amount_to_buy = round(TRADE_AMOUNT_USDT / current_price, 6)
                    print(f"السعر الحالي: {current_price} | سيتم شراء كمية: {amount_to_buy}")
                    
                    # 3. أمر الشراء (تمت إضافة params={'price': current_price} لكي تقبلها v2)
                    buy_order = exchange.create_market_buy_order(symbol, amount_to_buy, params={'price': current_price})
                    
                    buy_price = buy_order['average']
                    amount_bought = buy_order['filled'] 
                    
                    print(f"✅ تم الشراء بنجاح! الكمية الفعلية: {amount_bought} بسعر {buy_price}")
                    
                    # 4. مراقبة الصفقة
                    in_position = True
                    while in_position:
                        ticker = exchange.fetch_ticker(symbol)
                        new_price = ticker['last']
                        profit_percent = ((new_price - buy_price) / buy_price) * 100
                        
                        print(f"⏳ {symbol} | السعر: {new_price} | الربح: {profit_percent:.2f}%")
                        
                        if profit_percent >= TAKE_PROFIT:
                            print("💰 تم جني الربح بنجاح!")
                            # أمر بيع (تمت إضافة السعر أيضاً)
                            exchange.create_market_sell_order(symbol, amount_bought, params={'price': new_price})
                            in_position = False
                        elif profit_percent <= STOP_LOSS:
                            print("🛑 وقف خسارة!")
                            # أمر بيع (تمت إضافة السعر أيضاً)
                            exchange.create_market_sell_order(symbol, amount_bought, params={'price': new_price})
                            in_position = False
                        
                        time.sleep(15)
                    time.sleep(120)
            except Exception as e:
                print(f"خطأ في {symbol}: {e}")
                time.sleep(30)

if __name__ == "__main__":
    start_bot()

